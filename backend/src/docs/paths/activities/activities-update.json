{
  "put": {
    "summary": "Editar uma atividade existente",
    "description": "Endpoint para editar uma atividade.",
    "tags": ["Activities"],
    "security": [
      {
        "bearerAuth": []
      }
    ],
     "parameters": [
      {
        "name": "id",
        "in": "path",
        "description": "Id da atividade",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "multipart/form-data": {
          "schema": {
            "$ref": "../../components/schemas.json#/ActivityUpdateSchema"
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../components/schemas.json#/ActivityCreatorResponseSchema"
            }
          }
        }
      },
      "400": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "../../components/responses.json#/BadRequest"
                }
              ]
            },
            "examples": {
              "invalidImageFormat": {
                "summary": "Formato de imagem inválido",
                "value": {
                  "error": "A imagem deve ser um arquivo PNG ou JPG"
                }
              },
              "genericBadRequest": {
                "summary": "Erro genérico de validação",
                "value": {
                  "error": "Informe os campos obrigatórios corretamente"
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../../components/responses.json#/Unauthorized"
      },
      "403": {
        "$ref": "../../components/responses.json#/Forbidden"
      },
      "404": {
        "description": "NotFound",
        "content": {
          "application/json": {
            "example": {
              "error": "Atividade não encontrada."
            }
          }
        }
      },
      "409": {
        "description": "Conflict",
        "content": {
          "application/json": {
            "examples": {
              "notActivityCreator": {
                "summary": "Usuário não é o criador da atividade",
                "value": {
                  "error": "Apenas o criador da atividade pode editar."
                }
              },
              "typeIdInvalid": {
                "summary": "Typo de atividade inválido",
                "value": {
                  "error": "Tipo de atividade não existe."
                }
              }
            }
          }
        }
      },
      "500": {
        "$ref": "../../components/responses.json#/InternalServerError"
      }
    }
  }
}
