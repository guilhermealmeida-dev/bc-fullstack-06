{
  "post": {
    "summary": "Criar uma atividade",
    "description": "Endpoint para criar atividade.",
    "tags": ["Activities"],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "multipart/form-data": {
          "schema": {
            "$ref": "../../components/schemas.json#/ActivityCreationSchema"
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../../components/schemas.json#/ActivityResponseSchema"
            }
          }
        }
      },
      "400": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "../../components/responses.json#/BadRequest"
                }
              ]
            },
            "examples": {
              "invalidActivityType": {
                "summary": "Tipo de atividade inexistente",
                "value": {
                  "error": "Tipo de atividade não existe"
                }
              },
              "invalidImageFormat": {
                "summary": "Formato de imagem inválido",
                "value": {
                  "error": "A imagem deve ser um arquivo PNG ou JPG"
                }
              },
              "genericBadRequest": {
                "summary": "Erro genérico de validação",
                "value": {
                  "error": "Informe os campos obrigatórios corretamente"
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../../components/responses.json#/Unauthorized"
      },
      "403": {
        "$ref": "../../components/responses.json#/Forbidden"
      },
      "500": {
        "$ref": "../../components/responses.json#/InternalServerError"
      }
    }
  }
}
