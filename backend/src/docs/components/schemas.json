      "email": {
        "type": "string",
        "format": "email",
        "description": "Endereço de e-mail do usuário"
      },
      "cpf": {
        "type": "string",
        "pattern": "^[0-9]{11}$",
        "description": "Número de CPF do usuário (somente números, 11 dígitos)"
      },
      "avatar": {
        "type": "string",
        "format": "uri",
        "description": "URL da imagem de avatar do usuário"
      },
      "xp": {
        "type": "integer",
        "example": 0,
        "description": "Quantidade de pontos de experiência (XP) do usuário"
      },
      "level": {
        "type": "integer",
        "example": 0,
        "description": "Nível atual do usuário baseado em XP"
      },
      "archievements": {
        "type": "array",
        "description": "Lista de conquistas desbloqueadas pelo usuário",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Nome da conquista"
            },
            "criterion": {
              "type": "string",
              "description": "Critério que define a conquista"
            }
          }
        },
        "example": [
          {
            "name": "string",
            "criterion": "string"
          }
        ]
      }
    }
  },

