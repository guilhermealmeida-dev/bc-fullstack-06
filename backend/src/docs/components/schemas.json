  "UserResponseSchema": {
    "type": "object",
    "title": "UserResponseSchema",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid",
        "description": "Identificador único do usuário"
      },
      "name": {
        "type": "string",
        "description": "Nome do usuário"
