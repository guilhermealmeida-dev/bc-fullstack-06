  "ActivityTypeSchema": {
    "type": "object",
    "title": "ActivityTypeSchema",
    "properties": {
      "id": {
        "type": "string",
        "format": "text",
        "description": "Id do tipo de atividade"
      },
      "name": {
        "type": "string",
        "format": "text",
        "description": "Nome do tipo de atividade"
      },
