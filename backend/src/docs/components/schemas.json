{
  "UserCreateSchema": {
    "title": "UserCreateSchema",
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Nome completo do usuário"
      },
      "email": {
        "type": "string",
        "format": "email",
        "description": "Endereço de e-mail válido do usuário"
      },
      "cpf": {
        "type": "string",
        "pattern": "^[0-9]{11}$",
        "description": "Número de CPF do usuário (somente números, 11 dígitos)"
      },
      "password": {
        "type": "string",
        "format": "password",
        "description": "Senha de acesso do usuário"
      }
    },
    "required": ["name", "email", "cpf", "password"]
  },

