{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "A aplicação é uma plataforma que permite o cadastro de usuários, além da criação, inscrição e gerenciamento de atividades.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "start": "npm run migrate-deploy && node dist/server.js",
    "migrate-deploy": "prisma migrate deploy --config=./prisma.config.js",
    "seed": "ts-node src/init-db.ts",
    "generate-doc": "ts-node src/generate-doc.ts",
    "migrate-dev": "prisma migrate dev --config=./src/prisma.config.ts",
    "generate": "prisma generate --config=./src/prisma.config.ts",
    "reset": "prisma migrate reset --config=./src/prisma.config.ts",
    "build": "tsc && npm run cp-resources",
    "cp-resources": "cp -r src/prisma/migrations dist/prisma/migrations && cp src/prisma/schema.prisma dist/prisma/schema.prisma && cp -r src/docs dist/docs",
    "test": "jest"
  },
  "author": "Guilherme Souza Almeida",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/cors": "^2.8.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "prisma": "^7.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.775.0",
    "@aws-sdk/s3-request-presigner": "^3.775.0",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@types/express": "^5.0.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.16.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
